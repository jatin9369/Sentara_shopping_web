# Razorpay Payment Gateway Configuration
# Get your keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# JWT Secret (change in production!)
JWT_SECRET=sentara_jwt_secret_2024

# Server port
PORT=3000

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# SMS Gateway API Configuration (Fill in either of these options for real SMS OTP delivery)
# Option 1: Fast2SMS (Recommended for India mobile numbers)
# Sign up at https://www.fast2sms.com to get a free API Key
FAST2SMS_API_KEY=

# Option 2: Twilio (Global SMS Gateway)
# Sign up at https://www.twilio.com to get free credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Gemini AI Support Chatbot API Configuration
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=
